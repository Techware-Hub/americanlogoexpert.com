# Hostinger Email SMTP (use smtp.titan.email instead if your mailbox uses Titan Email)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=Info@americanlogoexpert.com

# Add the Hostinger mailbox password in your local .env.local or hosting panel.
# Never commit the real password to source control.
SMTP_PASS=your_hostinger_email_password

MAIL_FROM=Info@americanlogoexpert.com
MAIL_TO=Info@americanlogoexpert.com
